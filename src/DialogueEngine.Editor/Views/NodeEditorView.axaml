<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DialogueEngine.Editor.ViewModels"
             x:Class="DialogueEngine.Editor.Views.NodeEditorView"
             x:DataType="vm:NodeEditorViewModel">

  <ScrollViewer Padding="16,12">
    <StackPanel Spacing="10">

      <!-- Identité -->
      <TextBlock Text="Nœud" FontSize="14" FontWeight="SemiBold" />

      <Grid ColumnDefinitions="110,*,16,120,*">
        <TextBlock Grid.Column="0" Text="ID" VerticalAlignment="Center" FontSize="12" />
        <TextBox   Grid.Column="1" Text="{Binding Id}" Watermark="node_id" />

        <TextBlock Grid.Column="3" Text="Condition" VerticalAlignment="Center" FontSize="12" />
        <TextBox   Grid.Column="4" Text="{Binding ConditionKey}" Watermark="(script key)" />
      </Grid>

      <Grid ColumnDefinitions="110,*,16,120,*">
        <TextBlock Grid.Column="0" Text="Conséquence" VerticalAlignment="Center" FontSize="12" />
        <TextBox   Grid.Column="1" Text="{Binding ConsequenceKey}" Watermark="(script key)" />

        <TextBlock Grid.Column="3" Text="Cancel" VerticalAlignment="Center" FontSize="12" />
        <TextBox   Grid.Column="4" Text="{Binding CancelConsequenceKey}" Watermark="(script key)" />
      </Grid>

      <Separator />

      <!-- Texte -->
      <TextBlock Text="Texte" FontSize="14" FontWeight="SemiBold" />
      <TextBox Text="{Binding Text}"
               Watermark="Texte prononcé par le NPC…"
               AcceptsReturn="True" MinHeight="72" />

      <Separator />

      <!-- Réponses -->
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Réponses" FontSize="14" FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <Button Content="+ Réponse" Command="{Binding AddResponseCommand}" />
      </StackPanel>

      <ItemsControl ItemsSource="{Binding Responses}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:ResponseViewModel">
            <Border Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                    CornerRadius="6" Padding="10,8" Margin="0,4">
              <StackPanel Spacing="6">

                <!-- En-tête réponse -->
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Réponse"
                             FontSize="12" FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button Content="▲" FontSize="10" Padding="4,2"
                            Command="{Binding $parent[UserControl].((vm:NodeEditorViewModel)DataContext).MoveResponseUpCommand}"
                            CommandParameter="{Binding}" />
                    <Button Content="▼" FontSize="10" Padding="4,2"
                            Command="{Binding $parent[UserControl].((vm:NodeEditorViewModel)DataContext).MoveResponseDownCommand}"
                            CommandParameter="{Binding}" />
                    <Button Content="✕" FontSize="10" Padding="4,2"
                            Command="{Binding $parent[UserControl].((vm:NodeEditorViewModel)DataContext).RemoveResponseCommand}"
                            CommandParameter="{Binding}" />
                  </StackPanel>
                </Grid>

                <!-- Texte -->
                <TextBox Text="{Binding Text}" Watermark="Texte affiché au joueur…" />

                <!-- Clés -->
                <Grid ColumnDefinitions="100,*,12,110,*">
                  <TextBlock Grid.Column="0" Text="Condition"
                             VerticalAlignment="Center" FontSize="12" />
                  <TextBox   Grid.Column="1" Text="{Binding ConditionKey}"
                             Watermark="(optionnel)" FontSize="12" />

                  <TextBlock Grid.Column="3" Text="Conséquence"
                             VerticalAlignment="Center" FontSize="12" />
                  <TextBox   Grid.Column="4" Text="{Binding ConsequenceKey}"
                             Watermark="(optionnel)" FontSize="12" />
                </Grid>

                <!-- Nœuds suivants -->
                <TextBlock Text="Nœuds suivants (un par ligne, ordre de priorité)"
                           FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBox Text="{Binding NextNodeIds}"
                         Watermark="node_id_1&#x0a;node_id_2"
                         AcceptsReturn="True" MinHeight="52" FontSize="12" />

              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>
