<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sample1.ViewModels"
             x:Class="Sample1.Views.OutcomeView"
             x:DataType="vm:OutcomeViewModel">

  <Grid RowDefinitions="*,Auto,*">
    <StackPanel Grid.Row="1" Spacing="16" HorizontalAlignment="Center" MaxWidth="440">

      <TextBlock Text="═══════════════════════════════════"
                 Foreground="{StaticResource NesBorderBrush}"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="13" HorizontalAlignment="Center" />

      <TextBlock Text="{Binding Title}"
                 Foreground="{StaticResource NesGoldBrush}"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="18" FontWeight="Bold"
                 HorizontalAlignment="Center" />

      <TextBlock Text="═══════════════════════════════════"
                 Foreground="{StaticResource NesBorderBrush}"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="13" HorizontalAlignment="Center" />

      <Border Classes="NesBox" Margin="0,8">
        <TextBlock Text="{Binding Message}"
                   FontFamily="Consolas,Courier New,monospace"
                   FontSize="14" TextWrapping="Wrap"
                   Foreground="{StaticResource NesTextBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />
      </Border>

      <Button HorizontalAlignment="Center" Classes="NesBtn"
              Click="OnRestartClick">
        <TextBlock Text="▶  REJOUER  ◀"
                   Foreground="{StaticResource NesGoldBrush}"
                   FontFamily="Consolas,Courier New,monospace"
                   FontSize="15" FontWeight="Bold" />
      </Button>

    </StackPanel>
  </Grid>
</UserControl>
