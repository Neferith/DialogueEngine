<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Couleurs NES -->
  <Styles.Resources>
    <Color x:Key="NesBg">#050A14</Color>
    <Color x:Key="NesBox">#0D1F3C</Color>
    <Color x:Key="NesBorder">#4080FF</Color>
    <Color x:Key="NesText">#E8E8E8</Color>
    <Color x:Key="NesGold">#FFD700</Color>
    <Color x:Key="NesMuted">#6888AA</Color>
    <Color x:Key="NesGreen">#44FF88</Color>
    <Color x:Key="NesRed">#FF4444</Color>

    <SolidColorBrush x:Key="NesBgBrush"     Color="{StaticResource NesBg}" />
    <SolidColorBrush x:Key="NesBoxBrush"    Color="{StaticResource NesBox}" />
    <SolidColorBrush x:Key="NesBorderBrush" Color="{StaticResource NesBorder}" />
    <SolidColorBrush x:Key="NesTextBrush"   Color="{StaticResource NesText}" />
    <SolidColorBrush x:Key="NesGoldBrush"   Color="{StaticResource NesGold}" />
    <SolidColorBrush x:Key="NesMutedBrush"  Color="{StaticResource NesMuted}" />
    <SolidColorBrush x:Key="NesGreenBrush"  Color="{StaticResource NesGreen}" />
    <SolidColorBrush x:Key="NesRedBrush"    Color="{StaticResource NesRed}" />
  </Styles.Resources>

  <!-- Style de base fenêtre -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource NesBgBrush}" />
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
  </Style>

  <!-- TextBlock par défaut -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource NesTextBrush}" />
    <Setter Property="FontFamily" Value="Consolas,Courier New,monospace" />
  </Style>

  <!-- Boîte NES : bordure double effet -->
  <Style Selector="Border.NesBox">
    <Setter Property="Background"    Value="{StaticResource NesBoxBrush}" />
    <Setter Property="BorderBrush"   Value="{StaticResource NesBorderBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius"  Value="2" />
    <Setter Property="Padding"       Value="12,8" />
  </Style>

  <!-- Bouton NES -->
  <Style Selector="Button.NesBtn">
    <Setter Property="Background"    Value="Transparent" />
    <Setter Property="BorderBrush"   Value="{StaticResource NesBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground"    Value="{StaticResource NesGoldBrush}" />
    <Setter Property="FontFamily"    Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize"      Value="14" />
    <Setter Property="Padding"       Value="16,8" />
    <Setter Property="Cursor"        Value="Hand" />
  </Style>
  <Style Selector="Button.NesBtn:pointerover /template/ ContentPresenter">
    <Setter Property="Background"  Value="#1A3060" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource NesTextBrush}" />
  </Style>

  <!-- Titre NPC -->
  <Style Selector="TextBlock.NpcName">
    <Setter Property="Foreground"  Value="{StaticResource NesGoldBrush}" />
    <Setter Property="FontSize"    Value="13" />
    <Setter Property="FontWeight"  Value="Bold" />
    <Setter Property="FontFamily"  Value="Consolas,Courier New,monospace" />
  </Style>

  <!-- Texte dialogue -->
  <Style Selector="TextBlock.DialogueText">
    <Setter Property="Foreground"  Value="{StaticResource NesTextBrush}" />
    <Setter Property="FontSize"    Value="14" />
    <Setter Property="FontFamily"  Value="Consolas,Courier New,monospace" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="MinHeight"   Value="70" />
  </Style>

  <!-- Réponse sélectionnée -->
  <Style Selector="TextBlock.ResponseSelected">
    <Setter Property="Foreground"  Value="{StaticResource NesGoldBrush}" />
    <Setter Property="FontSize"    Value="13" />
    <Setter Property="FontFamily"  Value="Consolas,Courier New,monospace" />
  </Style>

  <!-- Réponse normale -->
  <Style Selector="TextBlock.ResponseNormal">
    <Setter Property="Foreground"  Value="{StaticResource NesMutedBrush}" />
    <Setter Property="FontSize"    Value="13" />
    <Setter Property="FontFamily"  Value="Consolas,Courier New,monospace" />
  </Style>

  <!-- TextBox NES -->
  <Style Selector="TextBox.NesInput">
    <Setter Property="Background"     Value="#0D1F3C" />
    <Setter Property="BorderBrush"    Value="{StaticResource NesBorderBrush}" />
    <Setter Property="Foreground"     Value="{StaticResource NesGoldBrush}" />
    <Setter Property="CaretBrush"     Value="{StaticResource NesGoldBrush}" />
    <Setter Property="FontFamily"     Value="Consolas,Courier New,monospace" />
    <Setter Property="FontSize"       Value="14" />
    <Setter Property="Padding"        Value="8,6" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

</Styles>
