<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sample2.ViewModels"
             x:Class="Sample2.Views.OutcomeView"
             x:DataType="vm:OutcomeViewModel">

  <Grid RowDefinitions="*,Auto,*">
    <StackPanel Grid.Row="1" Spacing="16" HorizontalAlignment="Center" MaxWidth="460">

      <TextBlock Text="══════════════════════════════════════"
                 Foreground="{StaticResource NesBorder}" FontSize="13"
                 HorizontalAlignment="Center" />

      <TextBlock Text="{Binding Title}"
                 Foreground="{StaticResource NesGreen}"
                 FontSize="20" FontWeight="Bold"
                 HorizontalAlignment="Center" />

      <!-- Badge compétence utilisée -->
      <Border HorizontalAlignment="Center"
              Background="#1A3060" BorderBrush="{StaticResource NesGold}"
              BorderThickness="1" Padding="12,4" CornerRadius="2">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Compétence utilisée :"
                     Foreground="{StaticResource NesMuted}" FontSize="11" />
          <TextBlock Text="{Binding EmotionLabel}"
                     Foreground="{StaticResource NesGold}"
                     FontSize="11" FontWeight="Bold" />
        </StackPanel>
      </Border>

      <TextBlock Text="══════════════════════════════════════"
                 Foreground="{StaticResource NesBorder}" FontSize="13"
                 HorizontalAlignment="Center" />

      <Border Classes="NesBox">
        <TextBlock Text="{Binding Message}"
                   FontSize="13" TextWrapping="Wrap"
                   Foreground="{StaticResource NesText}"
                   TextAlignment="Center"
                   HorizontalAlignment="Center" />
      </Border>

      <Button HorizontalAlignment="Center" Classes="NesBtn"
              Click="OnRestartClick">
        <TextBlock Text="▶  NOUVELLE MISSION  ◀"
                   Foreground="{StaticResource NesGold}"
                   FontSize="14" FontWeight="Bold" />
      </Button>

    </StackPanel>
  </Grid>
</UserControl>
