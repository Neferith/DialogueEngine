<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sample2.ViewModels"
             x:Class="Sample2.Views.DialogueView"
             x:DataType="vm:DialogueViewModel">

  <StackPanel Spacing="4" Margin="12,8">

    <!-- Nom du locuteur -->
    <TextBlock Text="{Binding SpeakerName}"
               Foreground="{StaticResource NesGold}"
               FontSize="12" FontWeight="Bold" />

    <!-- Texte avec typewriter -->
    <Border Background="#0D1F3C" BorderBrush="{StaticResource NesBorder}"
            BorderThickness="1" Padding="10,6" MinHeight="60">
      <Grid>
        <TextBlock Text="{Binding DisplayedText}"
                   Foreground="{StaticResource NesText}"
                   FontSize="13" TextWrapping="Wrap" />
        <TextBlock Text="▼" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Foreground="{StaticResource NesGold}" FontSize="12"
                   IsVisible="{Binding ShowContinueIndicator}" />
      </Grid>
    </Border>

    <!-- Réponses -->
    <ItemsControl ItemsSource="{Binding Responses}" IsVisible="{Binding IsTypingDone}">
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:DialogueResponseItem">
          <Button Background="Transparent" BorderThickness="0"
                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                  Padding="0,2"
                  Command="{Binding $parent[UserControl].((vm:DialogueViewModel)DataContext).SelectResponseCommand}"
                  CommandParameter="{Binding Index}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="►" Foreground="{StaticResource NesGold}" FontSize="12" />
              <TextBlock Text="{Binding Text}" FontSize="12"
                         Foreground="{StaticResource NesText}" TextWrapping="Wrap" />
            </StackPanel>
          </Button>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

  </StackPanel>
</UserControl>
