<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MapEditor.Avalonia.ViewModels"
        x:Class="MapEditor.Avalonia.Views.NewMapDialog"
        Title="Nouvelle map"
        Width="360" Height="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20" Spacing="10">

    <TextBlock Text="Créer une nouvelle map" FontWeight="Bold" FontSize="15" />

    <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

      <TextBlock Grid.Row="0" Grid.Column="0" Text="Identifiant :" VerticalAlignment="Center" Margin="0,0,0,8" />
      <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding MapId}" Margin="0,0,0,8" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Largeur :"    VerticalAlignment="Center" Margin="0,0,0,8" />
      <NumericUpDown Grid.Row="1" Grid.Column="1"
                     Value="{Binding Width}" Minimum="4" Maximum="256" Increment="1" FormatString="0"
                     Margin="0,0,0,8" />

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Hauteur :"    VerticalAlignment="Center" Margin="0,0,0,8" />
      <NumericUpDown Grid.Row="2" Grid.Column="1"
                     Value="{Binding Height}" Minimum="4" Maximum="256" Increment="1" FormatString="0"
                     Margin="0,0,0,8" />

      <TextBlock Grid.Row="3" Grid.Column="0" Text="Module :"     VerticalAlignment="Center" Margin="0,0,0,8" />
      <ComboBox  Grid.Row="3" Grid.Column="1"
                 ItemsSource="{Binding Modules}"
                 SelectedItem="{Binding SelectedModule}"
                 DisplayMemberBinding="{Binding Name}"
                 HorizontalAlignment="Stretch" Margin="0,0,0,8" />

      <TextBlock Grid.Row="4" Grid.Column="0" Text="Tile par défaut :" VerticalAlignment="Center" />
      <ComboBox  Grid.Row="4" Grid.Column="1"
                 ItemsSource="{Binding TileTypes}"
                 SelectedItem="{Binding SelectedDefaultTile}"
                 DisplayMemberBinding="{Binding Name}"
                 HorizontalAlignment="Stretch" />

    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,10,0,0">
      <Button Content="Annuler" Click="OnCancel" Width="90" />
      <Button Content="Créer"   Click="OnCreate"  Width="90" />
    </StackPanel>

  </StackPanel>
</Window>
