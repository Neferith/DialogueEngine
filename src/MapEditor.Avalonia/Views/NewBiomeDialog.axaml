<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MapEditor.Avalonia.Views.NewBiomeDialog"
        Title="Nouveau biome"
        Width="320" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="20" Spacing="10">

    <TextBlock Text="Créer un nouveau biome" FontWeight="Bold" FontSize="15" />

    <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" >

      <TextBlock Grid.Row="0" Grid.Column="0" Text="Identifiant :"
                 VerticalAlignment="Center" Margin="0,0,0,8" />
      <TextBox   Grid.Row="0" Grid.Column="1" x:Name="IdBox"
                 Watermark="stone_dungeon" Margin="0,0,0,8" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Nom :"
                 VerticalAlignment="Center" />
      <TextBox   Grid.Row="1" Grid.Column="1" x:Name="NameBox"
                 Watermark="Stone Dungeon" />

    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,10,0,0">
      <Button Content="Annuler" Click="OnCancel" Width="90" />
      <Button Content="Créer"   Click="OnCreate" Width="90" />
    </StackPanel>

  </StackPanel>
</Window>